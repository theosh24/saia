# Railway PostgreSQL (add PostgreSQL service in Railway dashboard → copy DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Claude AI (required for chat to work)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://saia578.com,https://www.saia578.com,https://saia-front.vercel.app

# Rate limiting (requests per 15 min per wallet)
RATE_LIMIT_PER_WALLET=100
