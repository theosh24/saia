{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@sdk/*": ["sdk/src/*"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["tests/**/*.ts", "sdk/src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
